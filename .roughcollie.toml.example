# CodeRoughcollie 示例配置
# 复制为 .roughcollie.toml 并根据实际情况修改

# === 数据库定义（命名 map，可多个）===

[databases.gaussdb-prod]
enabled = false
host = "10.0.1.100"
port = 5432
database = "roughcollie_audit"
username = "roughcollie"
password_env = "GAUSSDB_PASSWORD"
ssl_mode = "verify-full"
auth_method = "sha256"

[databases.gaussdb-prod.explain]
timeout_seconds = 30
max_cost_warning = 10000
max_cost_critical = 50000
buffers_threshold = 100000
enable_analyze = true
enable_buffers = true

[databases.gaussdb-prod.security]
enforce_readonly = true
allowed_commands = ["EXPLAIN", "SET", "SHOW"]

# === 项目定义（命名 map，引用数据库）===

[projects.order-service]
project_type = "gaussdb-sql"
baseline = "main"
git_repo = "."
database = "gaussdb-prod"

[projects.payment-service]
project_type = "java"
baseline = "dev"
git_repo = "."
database = "gaussdb-prod"

# === 全局配置 ===

[rules.ogexplain]
preset = "all"

[rules.astgrep]
# preset 是 lib/cr-rules 下的相对路径（{lang}/{category}），可多选：
#   java/security, java/database, java/code-standards, java/exception,
#   java/performance, java/multithreading, java/memory,
#   shell/security, shell/robustness, ...
# glob: "java/*" 启用 java 下全部类别（实现中）
preset = ["java/security", "java/database"]
severity_threshold = "warning"

[rules.complexity]
enabled = true
baseline_compare = true
warning_delta = 10
critical_delta = 25

[output]
format = "markdown"
path = "./audit-report.md"
exit_code_on_critical = 1
exit_code_on_warning = 0

# [codeweb] 段（三期，可选）：语义影响分析，子进程调用 codeweb
[codeweb]
# binary = "/usr/local/bin/codeweb"   # 缺省从 PATH 查找
timeout_secs = 120

# [projects.demo.codeweb]
# project_path = "/srv/demo"          # codeweb 项目目录（含 codeweb.toml）
# enabled = true                      # opt-in
